APP_NAME=Local AI SKU Dimensioner
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO

# Runtime data defaults to %LOCALAPPDATA%\LocalAISkuDimensioner on Windows.
# DATA_ROOT=C:\LocalAISkuDimensioner

# Optional explicit SQLite URL. Leave commented to derive it from DATA_ROOT.
# DATABASE_URL=sqlite+pysqlite:///C:/LocalAISkuDimensioner/database/app.db

# Local scan-upload and calibration-test image limits.
MAX_UPLOAD_MB=25
MIN_IMAGE_LONG_EDGE=1280
MIN_IMAGE_SHORT_EDGE=720
MAX_IMAGE_PIXELS=60000000
MAX_ADDITIONAL_IMAGES=5
MAX_UPLOAD_FILES_PER_REQUEST=8

# Phase 3 processing remains disabled until this local orthogonal rig has been
# physically qualified and these safe contract values have been configured.
CAPTURE_SETUP_ID=unconfigured
CAPTURE_SETUP_VERSION=unconfigured
CAPTURE_SETUP_QUALIFIED=false
CAPTURE_SETUP_TYPE=orthogonal_rig
CAPTURE_SETUP_MIN_OBJECT_MM=75
CAPTURE_SETUP_MAX_OBJECT_MM=400
CAPTURE_SETUP_MARKER_SIZE_UNCERTAINTY_MM=0.5
CAPTURE_SETUP_PLANE_UNCERTAINTY_MM=1.0
CAPTURE_SETUP_ORTHOGONALITY_UNCERTAINTY_DEG=0.5
CAPTURE_SETUP_STANDOFF_UNCERTAINTY_MM=2.0
CAPTURE_SETUP_MAX_OFF_PLANE_MM=0

# Deterministic Phase 3 reconciliation and resource ceilings.
MEASUREMENT_ACCEPTABLE_DISAGREEMENT_MM=5
MEASUREMENT_ACCEPTABLE_DISAGREEMENT_PERCENT=3
MEASUREMENT_WARNING_DISAGREEMENT_MM=10
MEASUREMENT_WARNING_DISAGREEMENT_PERCENT=6
MEASUREMENT_USABLE_QUALITY=0.70
MEASUREMENT_WEAK_QUALITY=0.55
MEASUREMENT_STRONGER_SOURCE_QUALITY_LEAD=0.15
MEASUREMENT_WEAKER_SOURCE_UNCERTAINTY_RATIO=2
MEASUREMENT_MAX_RECTIFIED_EDGE_PX=4096
MEASUREMENT_MAX_RECTIFIED_PIXELS=16000000
MEASUREMENT_MAX_PHYSICAL_EXTENT_MM=1500
MEASUREMENT_MAX_COMPONENTS=1024
MEASUREMENT_MAX_CANDIDATES=64
# The lease must be strictly longer than the total synchronous deadline.
MEASUREMENT_PROCESSING_DEADLINE_SECONDS=30
MEASUREMENT_PROCESSING_LEASE_SECONDS=120

# The Vite development client uses the backend proxy for this relative path.
VITE_API_BASE_URL=/api
